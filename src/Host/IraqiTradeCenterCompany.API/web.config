<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config مخصّص لاستضافة API على IIS.

  المشاكل التي يحلّها (وكانت تظهر افتراضياً):
    1) IIS WebDAV module يخطف طلبات DELETE/PUT/MOVE/COPY/PROPFIND/UNLOCK ويُرجع
       405 Method Not Allowed قبل أن تصل للـ ASP.NET Core. نُزيله نهائياً
       على مستوى التطبيق.
    2) الـ handlers الافتراضية مثل WebDAV و OPTIONSVerbHandler و TRACEVerbHandler
       تُسجَّل قبل aspNetCore handler وتمنعها — نزيلها صراحةً.

  هذا الملف يُنسخ تلقائياً عند `dotnet publish` ويُدمج مع التحويلات الافتراضية
  لإضافة سطر <aspNetCore .../> الصحيح. الإعدادات هنا أعلاه (modules/handlers)
  تظل ثابتة.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <modules runAllManagedModulesForAllRequests="false">
        <remove name="WebDAVModule" />
      </modules>
      <handlers>
        <remove name="WebDAV" />
        <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
        <remove name="OPTIONSVerbHandler" />
        <remove name="TRACEVerbHandler" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\IraqiTradeCenterCompany.API.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
